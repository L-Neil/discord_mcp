# ---- Discord ----
# Bot token from the Discord Developer Portal (Bot > Reset Token).
# The bot must have the "MESSAGE CONTENT" privileged intent enabled in the portal,
# and View Channel + Read Message History permissions on the channels to be read.
DISCORD_BOT_TOKEN=your-discord-bot-token

# The single target guild (server) ID. Used as the default for list_channels.
DISCORD_GUILD_ID=000000000000000000

# ---- MCP connection auth ----
# Comma-separated bearer tokens handed out to users (one per person).
# A request to /mcp must send "Authorization: Bearer <one-of-these>".
# Generate with: npm run gen-tokens
MCP_AUTH_TOKENS=token-for-alice,token-for-bob,token-for-carol

# ---- Server ----
# Port the HTTP server listens on (default 3000).
PORT=3000

# Hard cap on how many messages read_messages may return in one call (default 500).
# read_messages auto-paginates the Discord REST API (100/page) up to this limit.
MAX_MESSAGE_LIMIT=500
