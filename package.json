{
  "name": "discord-mcp",
  "version": "1.0.0",
  "description": "Read-only Discord MCP server (Streamable HTTP) for summarizing/reporting Discord conversations from AI agents.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "dev": "node --env-file-if-exists=.env --import tsx --watch src/index.ts",
    "gen-tokens": "tsx scripts/gen-tokens.ts"
  },
  "dependencies": {
    "@discordjs/rest": "^2.4.0",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "discord-api-types": "^0.37.100",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
